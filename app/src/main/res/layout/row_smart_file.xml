<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#434242">

    <!-- ONLY ONE CHILD FOR MaterialCardView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- MAIN CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- FILE ICON -->
            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_file_generic"
                android:scaleType="centerInside"/>

            <!-- FILE INFO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="File name"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/txtInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TYPE • SIZE • PRIORITY • DATE • STATE"
                    android:textColor="#D1D5DB"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- SELECT CHECKBOX -->
            <CheckBox
                android:id="@+id/checkSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- UPLOAD CONTROLS (OVERLAY – HIDDEN INITIALLY) -->
        <LinearLayout
            android:id="@+id/uploadControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btnPause"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_pause"/>

            <ImageView
                android:id="@+id/btnResume"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_media_play"/>

            <ImageView
                android:id="@+id/btnCancel"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"/>
        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
