<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- Top Header Actions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtHeaderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Smart Environment"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectAll"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select All"
                    android:visibility="gone"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_all" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenFileManager"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:icon="@drawable/ic_folder"
                    app:iconTint="@color/text_black"
                    android:contentDescription="Manual Manager" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/text_black"
                    android:contentDescription="Settings" />
            </LinearLayout>

            <!-- Account Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_color"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgAccount"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/text_black"
                            android:contentDescription="Account"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Connected Account"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/txtAccountStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Not signed in"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:ellipsize="end"
                                android:maxLines="1" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChangeAccount"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:stateListAnimator="@animator/button_scale_anim"
                            android:text="Change"
                            android:minWidth="0dp"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SCAN STATUS & FILTERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/scanProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary"
                    app:trackColor="@color/divider"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/txtProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Discovering your files..."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- Filter Row -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">
                    
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAll"
                            style="@style/Widget.GptBackup.FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All"
                            app:chipIcon="@drawable/ic_all"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPhotos"
                            style="@style/Widget.GptBackup.FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Photos"
                            app:chipIcon="@drawable/ic_image" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVideos"
                            style="@style/Widget.GptBackup.FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Videos"
                            app:chipIcon="@drawable/ic_video" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAudio"
                            style="@style/Widget.GptBackup.FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio"
                            app:chipIcon="@drawable/ic_audio" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFiles"
                            style="@style/Widget.GptBackup.FilterChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Files"
                            app:chipIcon="@drawable/ic_file" />

                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- Priority Row -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/priorityChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chipHigh" style="@style/Widget.GptBackup.PriorityChip" android:layout_width="wrap_content" android:layout_height="34dp" android:text="High" app:chipCornerRadius="17dp" app:chipBackgroundColor="@color/chip_high_bg_selector"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipMedium" style="@style/Widget.GptBackup.PriorityChip" android:layout_width="wrap_content" android:layout_height="34dp" android:text="Medium" app:chipCornerRadius="17dp" app:chipBackgroundColor="@color/chip_medium_bg_selector"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipLow" style="@style/Widget.GptBackup.PriorityChip" android:layout_width="wrap_content" android:layout_height="34dp" android:text="Low" app:chipCornerRadius="17dp" app:chipBackgroundColor="@color/chip_low_bg_selector"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSmart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Compact Floating Action Button (Moved to Right Side - bottom|end) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnBackupHigh"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="Backup"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:iconSize="20dp"
        app:backgroundTint="@color/primary"
        app:icon="@drawable/ic_archive"
        app:iconTint="@color/white"
        app:elevation="4dp"/>

    <!-- Hidden views preserved for code compatibility -->
    <com.google.android.material.button.MaterialButton android:id="@+id/btnPause" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnResume" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnCancel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/btnApps" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ProgressBar android:id="@+id/progressUpload" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/txtUploadInfo" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/txtFileCount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <FrameLayout android:id="@+id/uploadOverlay" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
